# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Database (if used by non-Supabase scripts)
DATABASE_URL=postgresql://user:password@localhost:5432/vehicle_tracking

# Google Maps API Keys
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_DISTANCE_MATRIX_KEY=your_distance_matrix_api_key_here
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_public_google_maps_api_key_here

# Authentication (legacy/non-Supabase flows)
JWT_SECRET=your_jwt_secret_key_change_in_production

# Environment
NODE_ENV=development
